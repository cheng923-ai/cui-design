# Flask 配置
DEBUG=False
PORT=5000
SECRET_KEY=your-secret-key-here

# OpenAI API
OPENAI_API_KEY=sk-xxx
OPENAI_MODEL=gpt-4o

# 数据库
DATABASE_URL=sqlite:///cui_design.db
# 或 PostgreSQL
# DATABASE_URL=postgresql://user:password@localhost/cui_design

# Redis (可选)
REDIS_URL=redis://localhost:6379/0

# 存储
STORAGE_PATH=./uploads
MAX_UPLOAD_SIZE=50000000

# 日志
LOG_LEVEL=INFO
